{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 90,
	"singleQuote": true,
	"semi": true,
	"trailingComma": "all",
	"bracketSpacing": true,
	"bracketSameLine": true,
	"arrowParens": "always",
	"endOfLine": "lf",
	"htmlWhitespaceSensitivity": "ignore",
	"svelte": {
		"allowShorthand": true,
		"indentScriptAndStyle": true,
		"sortOrder": "options-scripts-markup-styles"
	},
	"ignorePatterns": [
		".claude/",
		"delightstack/",
		".svelte-kit/",
		"build/",
		".wrangler/",
		".vercel/",
		"node_modules/",
		"pnpm-lock.yaml",
		"static/",
		"media/",
		"legacy-content/"
	]
}
