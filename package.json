{
  "name": "brianschwabauer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "dev:images": "DOCKER_HOST=${DOCKER_HOST:-unix:///var/run/docker.sock} wrangler dev --config wrangler.images.toml --port 8788 --persist-to .wrangler/state",
    "dev:all": "concurrently -n site,images -c cyan,magenta \"pnpm dev\" \"pnpm dev:images\"",
    "build:packages": "pnpm --filter @delightstack/utilities run build && pnpm --filter @delightstack/components run build",
    "build": "pnpm build:packages && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@sveltejs/adapter-cloudflare": "^5.1.0",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@types/video.js": "^7.3.58",
    "concurrently": "^9.0.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@auth/core": "^0.37.0",
    "@auth/sveltekit": "^1.7.0",
    "@cloudflare/containers": "^0.1.0",
    "@delightstack/components": "workspace:*",
    "@delightstack/images": "workspace:*",
    "@delightstack/utilities": "workspace:*",
    "@orama/orama": "^3.0.0",
    "@tiptap/core": "^2.10.0",
    "@tiptap/extension-heading": "^2.27.2",
    "@tiptap/extension-link": "^2.10.0",
    "@tiptap/pm": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "thumbhash": "^0.1.1",
    "video.js": "^8.23.7",
    "videojs-vtt-thumbnails": "^0.0.13"
  },
  "type": "module"
}
