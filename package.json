{
  "name": "brianschwabauer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply portfolio-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply portfolio-db --remote"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^5.1.0",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "drizzle-kit": "^0.30.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "wrangler": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@auth/core": "^0.37.0",
    "@auth/drizzle-adapter": "^1.7.0",
    "@auth/sveltekit": "^1.7.0",
    "@delightstack/components": "workspace:*",
    "@tiptap/core": "^2.10.0",
    "@tiptap/extension-image": "^2.10.0",
    "@tiptap/extension-link": "^2.10.0",
    "@tiptap/pm": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "drizzle-orm": "^0.38.0"
  },
  "type": "module"
}
